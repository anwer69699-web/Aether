UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if waitingForKeybind and input.KeyCode ~= Enum.KeyCode.Unknown then
        KEYBINDS[waitingForKeybind] = input.KeyCode; if KeyButtons[waitingForKeybind] then KeyButtons[waitingForKeybind].Text = input.KeyCode.Name end
        waitingForKeybind = nil; return
    end
    if input.KeyCode == Enum.KeyCode.U then main.Visible = not main.Visible; progressBar.Visible = main.Visible; return end
    if input.KeyCode == Enum.KeyCode.Space then spaceHeld = true; return end
    if input.KeyCode == KEYBINDS.SPEED then Enabled.SpeedBoost = not Enabled.SpeedBoost; if VisualSetters.SpeedBoost then VisualSetters.SpeedBoost(Enabled.SpeedBoost) end end
    if input.KeyCode == KEYBINDS.GALAXY then Enabled.Galaxy = not Enabled.Galaxy; if VisualSetters.Galaxy then VisualSetters.Galaxy(Enabled.Galaxy) end; if Enabled.Galaxy then setupGalaxyForce() else stopGalaxy() end end
    if input.KeyCode == KEYBINDS.BATAIMBOT then
        Enabled.BatAimbot = not Enabled.BatAimbot; if VisualSetters.BatAimbot then VisualSetters.BatAimbot(Enabled.BatAimbot) end
        if Enabled.BatAimbot then enforceMutual("BatAimbot"); lock_start() else lock_stop() end
    end
    if input.KeyCode == KEYBINDS.DROP then executeDrop() end
    if input.KeyCode == KEYBINDS.TPDOWN then executeTPDown() end
    if input.KeyCode == KEYBINDS.DESYNCS then
        Enabled.Desyncs = not Enabled.Desyncs; if VisualSetters.Desyncs then VisualSetters.Desyncs(Enabled.Desyncs) end; activateDesync()
    end
    if input.KeyCode == KEYBINDS.AUTOLEFT then
        Enabled.AutoLeft = not Enabled.AutoLeft; if VisualSetters.AutoLeft then VisualSetters.AutoLeft(Enabled.AutoLeft) end
        if Enabled.AutoLeft then enforceMutual("AutoLeft"); autoLeftPhase = 1; autoLeftWaiting = false end
    end
    if input.KeyCode == KEYBINDS.AUTORIGHT then
        Enabled.AutoRight = not Enabled.AutoRight; if VisualSetters.AutoRight then VisualSetters.AutoRight(Enabled.AutoRight) end
        if Enabled.AutoRight then enforceMutual("AutoRight"); autoRightPhase = 1; autoRightWaiting = false end
    end
end)

