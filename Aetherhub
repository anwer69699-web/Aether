        table.insert(desync_groundParts, {dot = dot, baseAngle = a, isOuter = true})
    end
    for i = 1, 20 do
        local a = (i / 20) * PI2
        local dot = Instance.new("Part"); dot.Anchored = true; dot.CanCollide = false; dot.CanTouch = false; dot.CanQuery = false
        dot.CastShadow = false; dot.Size = Vector3.new(0.15,0.15,0.15); dot.Shape = Enum.PartType.Ball
        dot.Material = Enum.Material.Neon; dot.Color = Color3.fromRGB(150, 210, 255)
        dot.CFrame = CFrame.new(pos.X + math.cos(a) * 1.8, pos.Y - 3.1, pos.Z + math.sin(a) * 1.8); dot.Parent = workspace
        table.insert(desync_groundParts, {dot = dot, baseAngle = a, isOuter = false})
    end
    
    desync_vfxConn = RunService.Heartbeat:Connect(function(dt)
        if not desync_ghostModel or not desync_ghostModel.Parent then return end
        pcall(function()
