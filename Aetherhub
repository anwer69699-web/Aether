RunService.Heartbeat:Connect(function()
    if not speedLabel or not speedLabel.Parent then return end
    pcall(function()
        local hrp = getChar() and getChar():FindFirstChild("HumanoidRootPart")
        if not hrp then speedLabel.Text = "SPD: 0"; return end
        local vel = hrp.AssemblyLinearVelocity; local hs = math.sqrt(vel.X*vel.X + vel.Z*vel.Z)
        local ds = math.floor(hs*10+0.5)/10
        speedLabel.TextColor3 = ds > 30 and Color3.fromRGB(255,85,85) or ds > 16 and Color3.fromRGB(255,200,85) or Color3.fromRGB(255,255,255)
        speedLabel.Text = "SPD: "..string.format("%.1f", ds)
    end)
end)

