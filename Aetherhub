-- ═══════════════════════════════════════════════════════════════
local guiVisible = true

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.U then
        guiVisible = not guiVisible
        if main and main.Parent then main.Visible = guiVisible end
        return
    end
    if input.KeyCode == Enum.KeyCode.Space then
        spaceHeld = true
        return
    end
    -- تحقق من كي باندات الأزرار
    for _, bindData in pairs(ButtonKeybinds) do
        if input.KeyCode == bindData.keyCode then
            bindData.toggleFunc()
            return
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Space then spaceHeld = false end
end)

