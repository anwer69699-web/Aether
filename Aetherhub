-- SYSTEM 0: SAFE CLEANUP
-- ═══════════════════════════════════════════════════════════════
do
    local function safeClean(obj)
        if not obj then return end
        pcall(function()
            for _, child in ipairs(obj:GetChildren()) do
                if child:GetAttribute("AETHER_HUB") then
                    child:Destroy()
                end
            end
        end)
    end
    safeClean(Player:FindFirstChild("PlayerGui"))
    safeClean(workspace:FindFirstChild("Aether_CoordESP"))
    pcall(function()
        local dbGui = game.CoreGui:FindFirstChild("DB")
        if dbGui then dbGui:Destroy() end
    end)
    pcall(function()
        local frGui = game.CoreGui:FindFirstChild("FR HUBLagger")
        if frGui then frGui:Destroy() end
    end)
    pcall(function()
        local dropGui = game.CoreGui:FindFirstChild("Aether_Drop")
        if dropGui then dropGui:Destroy() end
    end)
    task.wait(0.3)
end

local function tagInstance(inst)
    if inst then
        pcall(function() inst:SetAttribute("AETHER_HUB", true) end)
    end
end

