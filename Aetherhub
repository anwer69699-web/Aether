local function getMovementDirection()
    local c = Player.Character
    if not c then return Vector3.zero end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hum then return Vector3.zero end
    return hum.MoveDirection
end

local function resetVelocity()
    pcall(function()
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        local hum = c:FindFirstChildOfClass("Humanoid")
        if h then h.AssemblyLinearVelocity = Vector3.new(0, h.AssemblyLinearVelocity.Y, 0) end
        if hum then hum:Move(Vector3.zero, false) end
    end)
end

-- ═══════════════════════════════════════════════════════════════
-- STATE MANAGER (Lock/AutoLeft/AutoRight - mutual exclusion)
-- ═══════════════════════════════════════════════════════════════
local autoWalkId = 0
local autoRightId = 0

local function forceStopMovement()
    if CurrentMovementMode == "Lock" then
        if Connections.lock then
            Connections.lock:Disconnect()
            Connections.lock = nil
        end
        Enabled.Lock = false
        if VisualSetters.Lock then VisualSetters.Lock(false, true) end
    end
    if CurrentMovementMode == "AutoWalk" then
        autoWalkId = autoWalkId + 1
        Enabled.AutoWalk = false
        if VisualSetters.AutoWalk then VisualSetters.AutoWalk(false, true) end
    end
    if CurrentMovementMode == "AutoRight" then
        autoRightId = autoRightId + 1
        Enabled.AutoRight = false
        if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        pcall(function()
            local c = Player.Character
            if c then
                local hum = c:FindFirstChildOfClass("Humanoid")
                if hum then hum.AutoRotate = true end
            end
        end)
    end
    CurrentMovementMode = "None"
    resetVelocity()
end

local function setMovementState(newState, startFunc)
    if CurrentMovementMode == newState then return end
    forceStopMovement()
    if newState == "None" then return end
    CurrentMovementMode = newState
    startFunc()
end

-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 1: SPEED BOOST
-- ═══════════════════════════════════════════════════════════════
function startSpeedBoost()
    if Connections.speed then return end
    Connections.speed = RunService.Heartbeat:Connect(function()
        if not Enabled.SpeedBoost then return end
        if CurrentMovementMode ~= "None" then return end
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then return end
            local md = getMovementDirection()
            if md.Magnitude > 0.1 then
                local isStealingAttr = Player:GetAttribute("Stealing")
                local spd = Values.StealSpeed
                if not isStealingAttr then spd = Values.BoostSpeed end
                h.AssemblyLinearVelocity = Vector3.new(md.X * spd, h.AssemblyLinearVelocity.Y, md.Z * spd)
            end
        end)
    end)
end

function stopSpeedBoost()
    if Connections.speed then Connections.speed:Disconnect() Connections.speed = nil end
    resetVelocity()
end

-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 2: ANTI RAGDOLL
-- ═══════════════════════════════════════════════════════════════
function startAntiRagdoll()
    if Connections.antiRagdoll then return end
    Connections.antiRagdoll = RunService.Heartbeat:Connect(function()
        if not Enabled.AntiRagdoll then return end
        local char = Player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Ragdoll or st == Enum.HumanoidStateType.FallingDown then
            hum:ChangeState(Enum.HumanoidStateType.Running)
            hum.PlatformStand = false
            workspace.CurrentCamera.CameraSubject = hum
            pcall(function()
                local pm = Player.PlayerScripts:FindFirstChild("PlayerModule")
                if pm then
                    local cm = pm:FindFirstChild("ControlModule")
                    if cm then require(cm).Enable() end
                end
            end)
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                root.AssemblyLinearVelocity = Vector3.zero
                root.RotVelocity = Vector3.zero
            end
        end
        for _, obj in char:GetDescendants() do
            if obj:IsA("Motor6D") and not obj.Enabled then obj.Enabled = true end
        end
    end)
end

function stopAntiRagdoll()
    if Connections.antiRagdoll then
        Connections.antiRagdoll:Disconnect()
        Connections.antiRagdoll = nil
    end
end

-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 3: FAST STEAL
-- ═══════════════════════════════════════════════════════════════
local FastStealLoop = nil
local FastStealActive = false

function startFastSteal()
    if FastStealLoop then return end
    FastStealActive = true
    FastStealLoop = task.spawn(function()
        while FastStealActive do
            task.wait(0.05)
            pcall(function()
                local char = Player.Character
                if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local plots = workspace:FindFirstChild("Plots")
                if plots then
                    for _, plot in pairs(plots:GetChildren()) do
                        if not plot:IsA("Model") then continue end
                        local pods = plot:FindFirstChild("AnimalPodiums")
                        if not pods then continue end
                        for _, pod in pairs(pods:GetChildren()) do
                            if not pod:IsA("Model") then continue end
                            local base = pod:FindFirstChild("Base")
                            if not base then continue end
                            local spawnPart = base:FindFirstChild("Spawn")
                            if not spawnPart then continue end
                            local att = spawnPart:FindFirstChild("PromptAttachment")
                            if not att then continue end
                            for _, child in pairs(att:GetChildren()) do
                                if child:IsA("ProximityPrompt") then
                                    child.HoldDuration = Values.STEAL_DURATION
                                    child.RequiresLineOfSight = false
                                    child.Exclusivity = Enum.Exclusivity.None
                                    child.MaxActivationDistance = 12
                                end
                            end
                        end
                    end
                end

                local searchRadius = 25
                local region = Region3.new(
                    hrp.Position - Vector3.new(searchRadius, 20, searchRadius),
                    hrp.Position + Vector3.new(searchRadius, 20, searchRadius)
                )
                local parts = workspace:FindPartsInRegion3(region, char, 200)
                for _, part in ipairs(parts) do
                    for _, child in ipairs(part:GetDescendants()) do
                        if child:IsA("ProximityPrompt") then
                            child.HoldDuration = Values.STEAL_DURATION
                            child.RequiresLineOfSight = false
                            child.Exclusivity = Enum.Exclusivity.None
                            child.MaxActivationDistance = 15
                        end
                    end
                    for _, child in ipairs(part:GetChildren()) do
                        if child:IsA("ProximityPrompt") then
                            child.HoldDuration = Values.STEAL_DURATION
                            child.RequiresLineOfSight = false
                            child.Exclusivity = Enum.Exclusivity.None
                            child.MaxActivationDistance = 15
                        end
                    end
                end
            end)
        end
    end)
end

function stopFastSteal()
    FastStealActive = false
    if FastStealLoop then
        task.cancel(FastStealLoop)
        FastStealLoop = nil
    end
end

-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 4: LOCK
-- ═══════════════════════════════════════════════════════════════
local function findNearestEnemy(myHRP)
    local nearest = nil
    local nearestDist = math.huge
    local nearestTorso = nil
    for _, p in Players:GetPlayers() do
        if p ~= Player and p.Character then
            local eh = p.Character:FindFirstChild("HumanoidRootPart")
            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if eh and hum and hum.Health > 0 then
                local d = (eh.Position - myHRP.Position).Magnitude
                if d < nearestDist then
                    nearestDist = d
                    nearest = eh
                    nearestTorso = torso or eh
                end
            end
        end
    end
    return nearest, nearestDist, nearestTorso
end

function startLock()
    if Connections.lock then return end
    Connections.lock = RunService.Heartbeat:Connect(function()
        if not Enabled.Lock then return end
        if CurrentMovementMode ~= "Lock" then return end
        pcall(function()
            local c = Player.Character
            if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart")
            if not h then return end
            local target, dist, torso = findNearestEnemy(h)
            if target and torso then
                local dir = torso.Position - h.Position
                local flat = Vector3.new(dir.X, 0, dir.Z)
                if flat.Magnitude > 1.5 then
                    local md = flat.Unit
                    h.AssemblyLinearVelocity = Vector3.new(md.X * Values.LockSpeed, h.AssemblyLinearVelocity.Y, md.Z * Values.LockSpeed)
                else
                    local tv = target.AssemblyLinearVelocity
                    h.AssemblyLinearVelocity = Vector3.new(tv.X, h.AssemblyLinearVelocity.Y, tv.Z)
                end
            end
        end)
    end)
end

function stopLock()
    if Connections.lock then
        Connections.lock:Disconnect()
        Connections.lock = nil
    end
    if CurrentMovementMode == "Lock" then CurrentMovementMode = "None" end
    resetVelocity()
end

