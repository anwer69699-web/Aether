local function executeSteal(prompt, name)
    if Player:GetAttribute("Stealing") == true then return end
    if isStealingPrompt then return end
    local now = tick(); if now - lastStealTime < Values.StealCooldown then return end
    if not StealData[prompt] then
        StealData[prompt] = {hold={}, trigger={}}
        pcall(function()
            if getconnections then
                for _, c in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do if c.Function then table.insert(StealData[prompt].hold, c.Function) end end
                for _, c in ipairs(getconnections(prompt.Triggered)) do if c.Function then table.insert(StealData[prompt].trigger, c.Function) end end
            end
        end)
    end
    isStealingPrompt = true; lastStealTime = now
    if ProgressLabel then ProgressLabel.Text = name or "STEALING..." end
    task.spawn(function()
        for i=1, 5 do for _, f in ipairs(StealData[prompt].hold) do task.spawn(f) end; task.wait(0.02) end
    end)
    if progressConnection then progressConnection:Disconnect() end
    local startTime = tick()
    progressConnection = RunService.Heartbeat:Connect(function()
        if not isStealingPrompt then progressConnection:Disconnect(); return end
        local prog = math.clamp((tick() - startTime) / Values.STEAL_DURATION, 0, 1)
        if ProgressBarFill then ProgressBarFill.Size = UDim2.new(prog, 0, 1, 0) end
        if ProgressPercentLabel then ProgressPercentLabel.Text = math.floor(prog * 100) .. "%" end
    end)
    task.spawn(function()
        task.wait(Values.STEAL_DURATION)
        for _, f in ipairs(StealData[prompt].trigger) do task.spawn(f) end
        if progressConnection then progressConnection:Disconnect() end
        ResetProgressBar(); isStealingPrompt = false
    end)
end

local antiLaggerActive = false
local antiLaggerConnections = {}
local eventCallCounts = {}
local RATE_LIMIT = 10
local RATE_WINDOW = 0.3
local originalHandlers = {}

local function startAntiLagger()
    if antiLaggerActive then return end
    antiLaggerActive = true
    local function protectRemoteEvent(remote)
        if not remote or not remote:IsA("RemoteEvent") then return end
        if originalHandlers[remote] then return end
        pcall(function()
            local connections = getconnections(remote.OnClientEvent)
            if not connections then return end
            originalHandlers[remote] = {}
            for _, conn in ipairs(connections) do
                if conn.Function then
                    local originalFunc = conn.Function
                    local funcId = tostring(originalFunc)
                    originalHandlers[remote][funcId] = originalFunc
                    conn.Function = function(...)
                        if not antiLaggerActive then return originalFunc(...) end
                        local now = tick()
                        if not eventCallCounts[funcId] then eventCallCounts[funcId] = {lastCall = 0, blocked = false, blockUntil = 0} end
                        local data = eventCallCounts[funcId]
                        if data.blocked and now < data.blockUntil then return nil end
                        local timeSinceLast = now - data.lastCall
                        if timeSinceLast < (1 / RATE_LIMIT) then data.blocked = true; data.blockUntil = now + RATE_WINDOW; return nil end
                        data.lastCall = now; data.blocked = false
                        return originalFunc(...)
                    end
                end
            end
        end)
    end
    pcall(function()
        for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
            if obj:IsA("RemoteEvent") then task.spawn(protectRemoteEvent, obj) end
        end
    end)
    table.insert(antiLaggerConnections, ReplicatedStorage.DescendantAdded:Connect(function(obj)
        if obj:IsA("RemoteEvent") then task.spawn(protectRemoteEvent, obj) end
    end))
    table.insert(antiLaggerConnections, RunService.Heartbeat:Connect(function()
        if not antiLaggerActive then return end
        local now = tick()
        for id, data in pairs(eventCallCounts) do
            if data.blocked and now >= data.blockUntil then data.blocked = false end
        end
    end))
end

local function stopAntiLagger()
    antiLaggerActive = false
    for remote, handlers in pairs(originalHandlers) do
        pcall(function()
            if remote and remote.Parent then
                local connections = getconnections(remote.OnClientEvent)
                if connections then
                    for _, conn in ipairs(connections) do
                        if conn.Function and handlers[tostring(conn.Function)] then conn.Function = handlers[tostring(conn.Function)] end
                    end
                end
            end
        end)
    end
    originalHandlers = {}; eventCallCounts = {}
    for _, conn in ipairs(antiLaggerConnections) do if conn then pcall(function() conn:Disconnect() end) end end
    antiLaggerConnections = {}
end

