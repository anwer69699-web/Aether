-- SYSTEM 5: GALAXY MODE
-- ═══════════════════════════════════════════════════════════════
local galaxyVF = nil
local galaxyAtt = nil
local galaxyOn = false
local hopsOn = false
local lastHop = 0
local spaceHeld = false
local origJP = 50

local function captureJP()
    local c = Player.Character
    if c then
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hum and hum.JumpPower > 0 then origJP = hum.JumpPower end
    end
end
task.spawn(function() task.wait(1) captureJP() end)
Player.CharacterAdded:Connect(function() task.wait(1) captureJP() end)

local function setupGalaxyPhysics()
    pcall(function()
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        if galaxyVF then galaxyVF:Destroy() end
        if galaxyAtt then galaxyAtt:Destroy() end
        galaxyAtt = Instance.new("Attachment")
        galaxyAtt.Parent = h
        galaxyVF = Instance.new("VectorForce")
        galaxyVF.Attachment0 = galaxyAtt
        galaxyVF.ApplyAtCenterOfMass = true
        galaxyVF.RelativeTo = Enum.ActuatorRelativeTo.World
        galaxyVF.Force = Vector3.zero
        galaxyVF.Parent = h
    end)
    pcall(function()
        local c = Player.Character
        if c then
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum then
                local r = math.sqrt((196.2 * Values.GalaxyGravityPercent / 100) / 196.2)
                hum.JumpPower = origJP * r
            end
        end
    end)
end

function startGalaxy()
    if galaxyOn then return end
    galaxyOn = true
    hopsOn = true
    setupGalaxyPhysics()
    if not Connections.galaxy then
        Connections.galaxy = RunService.Heartbeat:Connect(function()
            if not galaxyOn then return end
            if hopsOn and spaceHeld then
                pcall(function()
                    local c = Player.Character
                    if not c then return end
                    local h = c:FindFirstChild("HumanoidRootPart")
                    local hum = c:FindFirstChildOfClass("Humanoid")
                    if h and hum and hum.FloorMaterial == Enum.Material.Air and tick() - lastHop > 0.08 then
                        lastHop = tick()
                        h.AssemblyLinearVelocity = Vector3.new(h.AssemblyLinearVelocity.X, Values.HOP_POWER, h.AssemblyLinearVelocity.Z)
                    end
                end)
            end
            if galaxyVF and galaxyOn then
                pcall(function()
                    local c = Player.Character
                    if not c then return end
                    local mass = 0
                    for _, p in c:GetDescendants() do
                        if p:IsA("BasePart") then mass = mass + p:GetMass() end
                    end
                    local tg = 196.2 * (Values.GalaxyGravityPercent / 100)
                    galaxyVF.Force = Vector3.new(0, mass * (196.2 - tg) * 0.95, 0)
                end)
            end
        end)
    end
end

function stopGalaxy()
    galaxyOn = false
    hopsOn = false
    if Connections.galaxy then
        Connections.galaxy:Disconnect()
        Connections.galaxy = nil
    end
    if galaxyVF then galaxyVF:Destroy() galaxyVF = nil end
    if galaxyAtt then galaxyAtt:Destroy() galaxyAtt = nil end
    pcall(function()
        local c = Player.Character
        if c then
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum then hum.JumpPower = origJP end
        end
    end)
end

