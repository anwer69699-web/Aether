local function StopDrop()
    DropActive = false; isDropping = false
    for _, c in ipairs(DropConns) do pcall(function() if typeof(c) == "RBXScriptConnection" then c:Disconnect() else task.cancel(c) end end) end
    DropConns = {}
    pcall(function() if ActionButtonLabels.DROP then ActionButtonLabels.DROP.TextColor3 = Color3.new(1,1,1); ActionButtonLabels.DROP.Parent.BackgroundColor3 = Color3.fromRGB(40, 50, 80) end end)
end

local function StartDrop()
    if DropActive then return end
    DropActive = true; isDropping = true
    pcall(function() if ActionButtonLabels.DROP then ActionButtonLabels.DROP.TextColor3 = Color3.new(1,1,1); ActionButtonLabels.DROP.Parent.BackgroundColor3 = DropColorOn end end)
    table.insert(DropConns, RunService.Stepped:Connect(function()
        if not DropActive then return end
        pcall(function() for _, p in ipairs(Players:GetPlayers()) do if p ~= Player and p.Character then for _, a in ipairs(p.Character:GetChildren()) do if a:IsA("BasePart") then a.CanCollide = false end end end end end)
    end))
    coroutine.resume(coroutine.create(function()
        while DropActive do
            pcall(function()
                RunService.Heartbeat:Wait()
                local c = getChar(); local h = c and c:FindFirstChild("HumanoidRootPart")
                if h then
                    local v = h.AssemblyLinearVelocity
                    h.AssemblyLinearVelocity = v * 5000 + Vector3.new(0, 5000, 0)
                    RunService.RenderStepped:Wait()
                    if h.Parent then h.AssemblyLinearVelocity = v end
                    RunService.Stepped:Wait()
                    if h.Parent then h.AssemblyLinearVelocity = v + Vector3.new(0, 0.1, 0) end
                end
            end)
        end
    end))
    task.delay(0.4, function() StopDrop() end)
end

local function executeTPDown()
    if tpDownActive then return end; tpDownActive = true
    pcall(function()
        local c = getChar(); if not c then tpDownActive = false; return end
        local h = c:FindFirstChild("HumanoidRootPart"); if not h then tpDownActive = false; return end
        local cf = h.CFrame; local rx,ry,rz = cf:ToEulerAnglesYXZ()
        h.AssemblyLinearVelocity = Vector3.new(h.AssemblyLinearVelocity.X, 0, h.AssemblyLinearVelocity.Z)
        h.CFrame = CFrame.new(cf.X,-7.30,cf.Z)*CFrame.Angles(rx,ry,rz)
    end)
    task.delay(0.3, function() tpDownActive = false end)
end

-- ==================== ULTRA FAST AUTO STEAL ====================
local isStealing = false
local autoStealConn = nil
local animalCache = {}
local promptCache = {}
local stealCache = {}

local function isMyPlot(plotName)
    local plot = workspace.Plots and workspace.Plots:FindFirstChild(plotName)
    if not plot then return false end
    local sign = plot:FindFirstChild("PlotSign"); if not sign then return false end
    local yb = sign:FindFirstChild("YourBase")
    return yb and yb:IsA("BillboardGui") and yb.Enabled == true
end

local function scanPlot(plot)
    if not plot or not plot:IsA("Model") then return end
    if isMyPlot(plot.Name) then return end
    local podiums = plot:FindFirstChild("AnimalPodiums"); if not podiums then return end
    for _, pod in ipairs(podiums:GetChildren()) do
        if pod:IsA("Model") and pod:FindFirstChild("Base") then
            local uid = plot.Name .. "_" .. pod.Name
            for _, ex in ipairs(animalCache) do if ex.uid == uid then return end end
            table.insert(animalCache, { name = pod.Name, plot = plot.Name, slot = pod.Name, worldPosition = pod:GetPivot().Position, uid = uid })
        end
    end
end

local function findPromptCached(ad)
    if not ad then return nil end
    local cp = promptCache[ad.uid]
    if cp and cp.Parent then return cp end
    local plots = workspace:FindFirstChild("Plots"); if not plots then return nil end
    local plot  = plots:FindFirstChild(ad.plot);    if not plot  then return nil end
    local pods  = plot:FindFirstChild("AnimalPodiums"); if not pods then return nil end
    local pod   = pods:FindFirstChild(ad.slot);     if not pod   then return nil end
    local base  = pod:FindFirstChild("Base");        if not base  then return nil end
    local sp    = base:FindFirstChild("Spawn");      if not sp    then return nil end
    local function searchPrompt(obj) for _, ch in ipairs(obj:GetDescendants()) do if ch:IsA("ProximityPrompt") then return ch end end end
    local att = sp:FindFirstChild("PromptAttachment")
    local prompt = nil
    if att then for _, p in ipairs(att:GetChildren()) do if p:IsA("ProximityPrompt") then prompt = p; break end end end
    if not prompt then prompt = searchPrompt(sp) end
    if prompt then promptCache[ad.uid] = prompt end
    return prompt
end

local function buildCallbacks(prompt)
    if stealCache[prompt] then return end
    local data = { holdCallbacks = {}, triggerCallbacks = {}, ready = true }
    local ok1, c1 = pcall(getconnections, prompt.PromptButtonHoldBegan)
    if ok1 and type(c1) == "table" then for _, conn in ipairs(c1) do if type(conn.Function) == "function" then table.insert(data.holdCallbacks, conn.Function) end end end
    local ok2, c2 = pcall(getconnections, prompt.Triggered)
    if ok2 and type(c2) == "table" then for _, conn in ipairs(c2) do if type(conn.Function) == "function" then table.insert(data.triggerCallbacks, conn.Function) end end end
    if #data.holdCallbacks > 0 or #data.triggerCallbacks > 0 then stealCache[prompt] = data end
end

local function execStealInstant(prompt, animalName)
    local data = stealCache[prompt]
    if not data or not data.ready then return false end
    data.ready = false; isStealing = true
    if ProgressLabel then ProgressLabel.Text = animalName or "STEAL..." end
    if ProgressBarFill then ProgressBarFill.Size = UDim2.new(1, 0, 1, 0) end
    if ProgressPercentLabel then ProgressPercentLabel.Text = "100%" end
    for _, fn in ipairs(data.holdCallbacks) do task.spawn(fn) end
    for _, fn in ipairs(data.triggerCallbacks) do task.spawn(fn) end
    task.delay(Values.STEAL_COOLDOWN, function()
        isStealing = false; data.ready = true
        if ProgressLabel then ProgressLabel.Text = "READY" end
        if ProgressBarFill then ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
        if ProgressPercentLabel then ProgressPercentLabel.Text = "" end
    end)
    return true
end

local function startAutoStealLoop()
    if autoStealConn then autoStealConn:Disconnect() end
    autoStealConn = RunService.Stepped:Connect(function()
        if not Enabled.AutoSteal or isStealing or isDropping then return end
        pcall(function()
            local char = getChar(); local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local best, bestD = nil, math.huge
            for _, ad in ipairs(animalCache) do
                if not isMyPlot(ad.plot) and ad.worldPosition then
                    local d = (hrp.Position - ad.worldPosition).Magnitude
                    if d < bestD then bestD = d; best = ad end
                end
            end
            if not best then return end
            if bestD < Values.STEAL_RADIUS then
                local prompt = promptCache[best.uid]
                if not prompt or not prompt.Parent then prompt = findPromptCached(best) end
                if prompt then buildCallbacks(prompt); execStealInstant(prompt, best.name) end
            end
        end)
    end)
end

local function stopAutoStealLoop()
    if autoStealConn then autoStealConn:Disconnect(); autoStealConn = nil end
    isStealing = false
    if ProgressLabel then ProgressLabel.Text = "READY" end
    if ProgressBarFill then ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
    if ProgressPercentLabel then ProgressPercentLabel.Text = "" end
end

task.spawn(function()
    task.wait(2)
    local plots = workspace:WaitForChild("Plots", 10); if not plots then return end
    for _, plot in ipairs(plots:GetChildren()) do if plot:IsA("Model") then scanPlot(plot) end end
    plots.ChildAdded:Connect(function(plot) if plot:IsA("Model") then task.wait(0.5); scanPlot(plot) end end)
    task.spawn(function()
        while task.wait(5) do
            animalCache = {}; promptCache = {}; stealCache = {}
            for _, plot in ipairs(plots:GetChildren()) do if plot:IsA("Model") then scanPlot(plot) end end
        end
    end)
end)

-- ==================== GALAXY MODE ====================
local galaxyVectorForce, galaxyAttachment = nil, nil
local originalJumpPower = 50

local function setupGalaxyForce()
    pcall(function()
        local c = getChar(); if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        if galaxyVectorForce then galaxyVectorForce:Destroy() end
        if galaxyAttachment then galaxyAttachment:Destroy() end
        galaxyAttachment = Instance.new("Attachment"); galaxyAttachment.Parent = hrp
        galaxyVectorForce = Instance.new("VectorForce"); galaxyVectorForce.Attachment0 = galaxyAttachment
        galaxyVectorForce.ApplyAtCenterOfMass = true; galaxyVectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
        galaxyVectorForce.Parent = hrp
    end)
end

local function updateGalaxy()
    if not Enabled.Galaxy or not galaxyVectorForce then return end
    pcall(function()
        local char = getChar(); if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid"); local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        if hum:GetState() == Enum.HumanoidStateType.Ragdoll then galaxyVectorForce.Force = Vector3.new(0,0,0); return end
        local mass = 0
        for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then mass = mass + p:GetMass() end end
        local tg = Values.DEFAULT_GRAVITY * (Values.GravityLimit / 100)
        if hum.FloorMaterial ~= Enum.Material.Air and not spaceHeld then
            galaxyVectorForce.Force = Vector3.new(0, 0, 0); hum.JumpPower = originalJumpPower; return
        end
        galaxyVectorForce.Force = Vector3.new(0, mass * (Values.DEFAULT_GRAVITY - tg) * 0.95, 0)
        local ratio = math.sqrt((Values.DEFAULT_GRAVITY * (Values.GravityLimit / 100)) / Values.DEFAULT_GRAVITY)
        hum.JumpPower = originalJumpPower * ratio
    end)
end

local function stopGalaxy()
    if galaxyVectorForce then galaxyVectorForce:Destroy(); galaxyVectorForce = nil end
    if galaxyAttachment then galaxyAttachment:Destroy(); galaxyAttachment = nil end
    pcall(function() local c = getChar(); if c then local hum = c:FindFirstChildOfClass("Humanoid"); if hum then hum.JumpPower = originalJumpPower end end end)
end

