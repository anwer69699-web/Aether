local function enforceMutual(keepKey)
    local ex = {AutoLeft = "AutoLeft", AutoRight = "AutoRight", BatAimbot = "BatAimbot"}
    for sys, _ in pairs(ex) do
        if sys ~= keepKey and Enabled[sys] then
            Enabled[sys] = false
