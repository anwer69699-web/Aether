-- SYSTEM 9: DROP (سكربت DB بنصف القوة - يشتغل مرة ويقفل)
-- ═══════════════════════════════════════════════════════════════
local dropFiring = false
local dropConns = {}

function executeDrop()
    if dropFiring then return end
    dropFiring = true

    -- CanCollide مؤقت للاعبين الثانيين
    local ccConn = RunService.Stepped:Connect(function()
        for _, p in Players:GetPlayers() do
            if p ~= Player and p.Character then
                for _, a in p.Character:GetChildren() do
                    if a:IsA("BasePart") then a.CanCollide = false end
                end
            end
        end
    end)
    table.insert(dropConns, ccConn)

    -- velocity exploit بنصف القوة (5000 بدل 10000) - يشتغل عدة مرات
    task.spawn(function()
        for _ = 1, 8 do
            if not dropFiring then break end
            pcall(function()
                local c = Player.Character
                if not c then return end
                local hrp = c:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local vel = hrp.AssemblyLinearVelocity
                hrp.AssemblyLinearVelocity = Vector3.new(vel.X * 5000, vel.Y + 5000, vel.Z * 5000)
                RunService.RenderStepped:Wait()
                if hrp and hrp.Parent then
                    hrp.AssemblyLinearVelocity = vel
                end
            end)
            task.wait(0.05)
        end
        task.wait(0.1)
        for _, c in ipairs(dropConns) do
            pcall(function() c:Disconnect() end)
        end
        table.clear(dropConns)
        dropFiring = false
        Enabled.Drop = false
        if VisualSetters.Drop then VisualSetters.Drop(false, true) end
    end)
end

function stopDrop()
    for _, c in ipairs(dropConns) do
        pcall(function() c:Disconnect() end)
    end
    table.clear(dropConns)
    dropFiring = false
end

