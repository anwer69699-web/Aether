-- SYSTEM 7: UNWALK
-- ═══════════════════════════════════════════════════════════════
local savedAnim = nil

function startUnwalk()
    pcall(function()
        local c = Player.Character
        if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hum then
            for _, t in hum:GetPlayingAnimationTracks() do t:Stop() end
        end
        local anim = c:FindFirstChild("Animate")
        if anim then
            savedAnim = anim:Clone()
            anim:Destroy()
        end
    end)
end

function stopUnwalk()
    pcall(function()
        local c = Player.Character
        if c and savedAnim then
            savedAnim:Clone().Parent = c
            savedAnim = nil
        end
    end)
end

-- ═══════════════════════════════════════════════════════════════
-- SYSTEM 8: AUTO LEFT / RIGHT
-- Left = يتحرك ويواجه اتجاه الحركة (طبيعي)
-- Right = نفس الحركة لكن الشخصية تواجه الاتجاه المعاكس (rotation معكوس)
-- ═══════════════════════════════════════════════════════════════
local LEFT_WP = {
    {Vector3.new(-474.78, -7.30, 92.59), 1},
    {Vector3.new(-482.58, -5.34, 97.59), 1},
    {Vector3.new(-474.73, -7.30, 95.37), 2},
    {Vector3.new(-474.76, -7.30, 27.94), 2},
    {Vector3.new(-482.54, -5.34, 22.31), 2},
}
local RIGHT_WP = {
    {Vector3.new(-474.76, -7.30, 27.94), 1},
    {Vector3.new(-482.54, -5.34, 22.31), 1},
    {Vector3.new(-475.33, -7.30, 22.41), 2},
    {Vector3.new(-475.15, -7.30, 92.84), 2},
    {Vector3.new(-482.28, -5.34, 97.93), 2},
}

function startAutoWalk()
    autoWalkId = autoWalkId + 1
    local myId = autoWalkId
    task.spawn(function()
        for _, wpData in ipairs(LEFT_WP) do
            local wp = wpData[1]
            local mode = wpData[2]
            if myId ~= autoWalkId then break end
            while myId == autoWalkId do
                local c = Player.Character
                if not c then break end
                local h = c:FindFirstChild("HumanoidRootPart")
                if not h then break end
                local dirXZ = Vector3.new(wp.X - h.Position.X, 0, wp.Z - h.Position.Z)
                if dirXZ.Magnitude < 0.5 then
                    h.CFrame = CFrame.new(wp.X, h.Position.Y, wp.Z)
                    break
                end
                local md = dirXZ.Unit
                local hum = c:FindFirstChildOfClass("Humanoid")
                if hum then hum:Move(md, false) end
                local spd = mode == 1 and Values.BoostSpeed or Values.StealSpeed
                h.AssemblyLinearVelocity = Vector3.new(md.X * spd, h.AssemblyLinearVelocity.Y, md.Z * spd)
                task.wait()
            end
            if myId ~= autoWalkId then break end
        end
        if myId == autoWalkId then
            resetVelocity()
            CurrentMovementMode = "None"
            Enabled.AutoWalk = false
            if VisualSetters.AutoWalk then VisualSetters.AutoWalk(false, true) end
        end
    end)
end

function stopAutoWalk()
    autoWalkId = autoWalkId + 1
    if CurrentMovementMode == "AutoWalk" then CurrentMovementMode = "None" end
    resetVelocity()
end

function startAutoRight()
    autoRightId = autoRightId + 1
    local myId = autoRightId
    task.spawn(function()
        -- عطل AutoRotate عشان نتحكم بالروتيشن يدويا
        pcall(function()
            local c = Player.Character
            if c then
                local hum = c:FindFirstChildOfClass("Humanoid")
                if hum then hum.AutoRotate = false end
            end
        end)

        for _, wpData in ipairs(RIGHT_WP) do
            local wp = wpData[1]
            local mode = wpData[2]
            if myId ~= autoRightId then break end
            while myId == autoRightId do
                local c = Player.Character
                if not c then break end
                local h = c:FindFirstChild("HumanoidRootPart")
                if not h then break end
                local dirXZ = Vector3.new(wp.X - h.Position.X, 0, wp.Z - h.Position.Z)
                if dirXZ.Magnitude < 0.5 then
                    h.CFrame = CFrame.lookAt(
                        Vector3.new(wp.X, h.Position.Y, wp.Z),
                        Vector3.new(wp.X, h.Position.Y, wp.Z) + Vector3.new(dirXZ.X, 0, dirXZ.Z)
                    )
                    break
                end
                local md = dirXZ.Unit
                local spd = mode == 1 and Values.BoostSpeed or Values.StealSpeed
                h.AssemblyLinearVelocity = Vector3.new(md.X * spd, h.AssemblyLinearVelocity.Y, md.Z * spd)
                -- واجه الاتجاه المعاكس للحركة
                h.CFrame = CFrame.lookAt(h.Position, h.Position + Vector3.new(-md.X, 0, -md.Z))
                task.wait()
            end
            if myId ~= autoRightId then break end
        end

        if myId == autoRightId then
            -- رجع AutoRotate
            pcall(function()
                local c = Player.Character
                if c then
                    local hum = c:FindFirstChildOfClass("Humanoid")
                    if hum then hum.AutoRotate = true end
                end
            end)
            resetVelocity()
            CurrentMovementMode = "None"
            Enabled.AutoRight = false
            if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
        end
    end)
end

function stopAutoRight()
    autoRightId = autoRightId + 1
    pcall(function()
        local c = Player.Character
        if c then
            local hum = c:FindFirstChildOfClass("Humanoid")
            if hum then hum.AutoRotate = true end
        end
    end)
    if CurrentMovementMode == "AutoRight" then CurrentMovementMode = "None" end
    resetVelocity()
end

