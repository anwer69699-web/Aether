                if entry.dot and entry.dot.Parent then
                    local radius = entry.isOuter and 3.2 or 1.8
                    local speed = entry.isOuter and 2.5 or -3.5
                    local a = entry.baseAngle + t * speed
                    local wave = math.abs(math.sin(t * 5 + entry.baseAngle)) * 0.2
                    entry.dot.CFrame = CFrame.new(currentPos.X + math.cos(a) * radius, currentPos.Y - 3.1 + wave, currentPos.Z + math.sin(a) * radius)
