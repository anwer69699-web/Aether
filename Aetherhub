-- ==================== KEYBINDS & PROTECTION ====================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    -- حل مشكلة عدم استجابة الاخفاء
    if input.KeyCode == Enum.KeyCode.U then 
        main.Visible = not main.Visible
        progressBar.Visible = main.Visible
        return 
    end
    
    if waitingForKeybind and input.KeyCode ~= Enum.KeyCode.Unknown then
        if CUSTOM_KEYBINDS[waitingForKeybind] then
            local key = input.KeyCode
            if not usedKeyBindsThisGame[key] then
                usedKeyBindsThisGame[key] = true
                CUSTOM_KEYBINDS[waitingForKeybind] = key
                local savedKey = waitingForKeybind; waitingForKeybind = nil
                if KeyButtons[savedKey] then KeyButtons[savedKey].Text = tostring(key.Name):sub(1,5):upper() end
            else waitingForKeybind = nil end
            return
        end
    end
    
    if input.KeyCode == Enum.KeyCode.Space then spaceHeld = true; return end
    
    if input.KeyCode == CUSTOM_KEYBINDS.SPEED then Enabled.SpeedBoost = not Enabled.SpeedBoost; if VisualSetters.SpeedBoost then VisualSetters.SpeedBoost(Enabled.SpeedBoost) end end
    if input.KeyCode == CUSTOM_KEYBINDS.GALAXY then Enabled.Galaxy = not Enabled.Galaxy; if VisualSetters.Galaxy then VisualSetters.Galaxy(Enabled.Galaxy) end; if Enabled.Galaxy then setupGalaxyForce() else stopGalaxy() end end
    if input.KeyCode == KEYBINDS.BATAIMBOT then Enabled.BatAimbot = not Enabled.BatAimbot; if VisualSetters.BatAimbot then VisualSetters.BatAimbot(Enabled.BatAimbot) end; if Enabled.BatAimbot then enforceMutual("BatAimbot"); lock_start() else lock_stop() end end
    if input.KeyCode == KEYBINDS.DROP then StartDrop() end
    if input.KeyCode == KEYBINDS.TPDOWN then executeTPDown() end
    if input.KeyCode == KEYBINDS.AUTOLEFT then Enabled.AutoLeft = not Enabled.AutoLeft; if VisualSetters.AutoLeft then VisualSetters.AutoLeft(Enabled.AutoLeft) end; if Enabled.AutoLeft then enforceMutual("AutoLeft"); autoLeftPhase = 1; autoLeftWaiting = false end end
    if input.KeyCode == KEYBINDS.AUTORIGHT then Enabled.AutoRight = not Enabled.AutoRight; if VisualSetters.AutoRight then VisualSetters.AutoRight(Enabled.AutoRight) end; if Enabled.AutoRight then enforceMutual("AutoRight"); autoRightPhase = 1; autoRightWaiting = false end end
    if input.KeyCode == CUSTOM_KEYBINDS.DESYNCS then Enabled.Desyncs = not Enabled.Desyncs; if VisualSetters.Desyncs then VisualSetters.Desyncs(Enabled.Desyncs) end; activateDesync() end
    if input.KeyCode == CUSTOM_KEYBINDS.ANTIRAGDOLL then Enabled.AntiRagdoll = not Enabled.AntiRagdoll; if VisualSetters.AntiRagdoll then VisualSetters.AntiRagdoll(Enabled.AntiRagdoll) end; if Enabled.AntiRagdoll then startAntiRagdoll() else stopAntiRagdoll() end end
    if input.KeyCode == CUSTOM_KEYBINDS.AUTOSTEAL then Enabled.AutoSteal = not Enabled.AutoSteal; if VisualSetters.AutoSteal then VisualSetters.AutoSteal(Enabled.AutoSteal) end; if Enabled.AutoSteal then startAutoStealLoop() else stopAutoStealLoop(); animalCache = {}; promptCache = {}; stealCache = {} end end
    if input.KeyCode == CUSTOM_KEYBINDS.GALAXYSKY then Enabled.GalaxySkyBright = not Enabled.GalaxySkyBright; if VisualSetters.GalaxySkyBright then VisualSetters.GalaxySkyBright(Enabled.GalaxySkyBright) end; if Enabled.GalaxySkyBright then enableGalaxySkyBright() else disableGalaxySkyBright() end end
end)

