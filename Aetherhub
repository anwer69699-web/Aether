    sBg.ZIndex = 6
    Instance.new("UICorner", sBg).CornerRadius = UDim.new(1, 0)

    local pct = (Values[vKey] - mn) / (mx - mn)
    local fill = Instance.new("Frame", sBg)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = T.accent
    fill.ZIndex = 7
