local function desync_rakhook(packet)
    if not packet then return end
    pcall(function()
        if packet.PacketId and packet.PacketId == 0x1B then
            local buf = packet.AsBuffer
            if buf and typeof(buf) == "string" and #buf >= 13 then
                desync_serverPosition = Vector3.new(buffer.readf32(buf, 1), buffer.readf32(buf, 5), buffer.readf32(buf, 9))
            end
        end
    end)
end

local function desync_createGhost(pos)
