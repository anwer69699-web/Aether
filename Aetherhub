end

local function lock_start()
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    hum.AutoRotate = true
    lock_hbConn = RunService.Heartbeat:Connect(function(dt)
        if not Enabled.BatAimbot then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        local humanoid = c:FindFirstChildOfClass("Humanoid")
        if not h or not humanoid then return end
        local bat = lock_getBat()
        if bat and bat.Parent ~= c then humanoid:EquipTool(bat) end
        local target, torso = lock_getNearest()
        if not target or not torso then lockTarget = nil; return end
        lockTarget = torso
        local targetPos = torso.Position
        local currentPos = h.Position
        local dir = targetPos - currentPos
        local flatDir = Vector3.new(dir.X, 0, dir.Z)
        local flatDist = flatDir.Magnitude
        local heightDiff = targetPos.Y - currentPos.Y
        local speed = Values.BatAimbotSpeed
        if flatDist > 2.5 then
            local moveDir = flatDir.Unit
            local yCorrection = math.clamp(heightDiff * 8, -speed * 0.3, speed * 0.3)
            h.AssemblyLinearVelocity = Vector3.new(moveDir.X * speed, yCorrection, moveDir.Z * speed)
        elseif flatDist > 1 then
            local tv = target.AssemblyLinearVelocity
            local yCorrection = math.clamp(heightDiff * 10, -speed * 0.35, speed * 0.35)
            h.AssemblyLinearVelocity = Vector3.new(tv.X * 0.85, yCorrection, tv.Z * 0.85)
        else
            local tv = target.AssemblyLinearVelocity
            local yCorrection = math.clamp(heightDiff * 12, -speed * 0.4, speed * 0.4)
            h.AssemblyLinearVelocity = Vector3.new(tv.X, yCorrection, tv.Z)
        end
        humanoid:Move(flatDir.Unit, false)
        if flatDist < 6 then
            local now = tick()
            if now - lastBatSwingTime > BAT_SWING_COOLDOWN then
                lastBatSwingTime = now
                local currentBat = lock_getBat()
                if currentBat and currentBat.Parent == c then pcall(function() currentBat:Activate() end) end
            end
        end
    end)
end

local function lock_stop()
    if lock_hbConn then lock_hbConn:Disconnect(); lock_hbConn = nil end
    lockTarget = nil
    local char = Player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate = true end
    end
end

