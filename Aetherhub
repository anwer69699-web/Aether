    hl.FillColor = Color3.fromRGB(0, 60, 180); hl.FillTransparency = 0
    hl.OutlineColor = Color3.fromRGB(0, 120, 255); hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Adornee = ghost; hl.Parent = ghost
    ghost.Parent = workspace; desync_ghostModel = ghost
    
    -- إنشاء الحلقات الأرضية بسرعة
    local PI2 = math.pi * 2
    for i = 1, 32 do
        local a = (i / 32) * PI2
        local dot = Instance.new("Part"); dot.Anchored = true; dot.CanCollide = false; dot.CanTouch = false; dot.CanQuery = false
        dot.CastShadow = false; dot.Size = Vector3.new(0.25,0.25,0.25); dot.Shape = Enum.PartType.Ball
