local antiLaggerActive = false
local antiLaggerConnections = {}
local eventCallCounts = {}
local originalHandlers = {}

local function startAntiLagger()
    if antiLaggerActive then return end
    antiLaggerActive = true
    local function protectRemoteEvent(remote)
        if not remote or not remote:IsA("RemoteEvent") or originalHandlers[remote] then return end
        pcall(function()
            if not getconnections then return end
            local connections = getconnections(remote.OnClientEvent)
            if not connections or type(connections) ~= "table" then return end
            originalHandlers[remote] = {}
            for _, conn in ipairs(connections) do
                if conn and conn.Function and type(conn.Function) == "function" then
                    local originalFunc = conn.Function; local funcId = tostring(originalFunc)
                    originalHandlers[remote][funcId] = originalFunc; local safeFunc = originalFunc
                    conn.Function = function(...)
                        if not antiLaggerActive then return safeFunc(...) end
                        local now = tick()
                        if not eventCallCounts[funcId] then eventCallCounts[funcId] = {lastCall = 0, blocked = false, blockUntil = 0} end
                        local data = eventCallCounts[funcId]
                        if data.blocked and now < data.blockUntil then return nil end
                        if (now - data.lastCall) < 0.1 then data.blocked = true; data.blockUntil = now + 0.3; return nil end
                        data.lastCall = now; data.blocked = false; return safeFunc(...)
                    end
                end
            end
        end)
    end
    pcall(function() for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do if obj:IsA("RemoteEvent") then task.spawn(protectRemoteEvent, obj) end end end)
    table.insert(antiLaggerConnections, ReplicatedStorage.DescendantAdded:Connect(function(obj) if obj and obj:IsA("RemoteEvent") then task.spawn(protectRemoteEvent, obj) end end))
    table.insert(antiLaggerConnections, RunService.Heartbeat:Connect(function()
        if not antiLaggerActive then return end
        local now = tick()
        for id, data in pairs(eventCallCounts) do if data.blocked and now >= data.blockUntil then data.blocked = false end end
    end))
end

local function stopAntiLagger()
    antiLaggerActive = false
    for remote, handlers in pairs(originalHandlers) do
        pcall(function()
            if remote and remote.Parent then
                local connections = getconnections and getconnections(remote.OnClientEvent)
                if connections then for _, conn in ipairs(connections) do if conn.Function and handlers[tostring(conn.Function)] then conn.Function = handlers[tostring(conn.Function)] end end end
            end
        end)
    end
    originalHandlers = {}; eventCallCounts = {}
    for _, conn in ipairs(antiLaggerConnections) do if conn then pcall(function() conn:Disconnect() end) end end
    antiLaggerConnections = {}
end

