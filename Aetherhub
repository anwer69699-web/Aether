-- SYSTEM 6: GALAXY SKY
-- ═══════════════════════════════════════════════════════════════
local origSky = nil
local gSky = nil
local gPlanets = {}
local gBloom = nil
local gCC = nil

function startGalaxySky()
    if gSky then return end
    origSky = Lighting:FindFirstChildOfClass("Sky")
    if origSky then origSky.Parent = nil end
    gSky = Instance.new("Sky")
    for _, k in ipairs({"SkyboxBk", "SkyboxDn", "SkyboxFt", "SkyboxLf", "SkyboxRt", "SkyboxUp"}) do
        gSky[k] = "rbxassetid://1534951537"
    end
    gSky.StarCount = 8000
    gSky.CelestialBodiesShown = false
    gSky.Parent = Lighting
    tagInstance(gSky)
    gBloom = Instance.new("BloomEffect")
    gBloom.Intensity = 1.2
    gBloom.Size = 35
    gBloom.Threshold = 0.8
    gBloom.Parent = Lighting
    tagInstance(gBloom)
    gCC = Instance.new("ColorCorrectionEffect")
    gCC.Saturation = 0.6
    gCC.Contrast = 0.25
    gCC.TintColor = Color3.fromRGB(100, 180, 255)
    gCC.Parent = Lighting
    tagInstance(gCC)
    Lighting.Ambient = Color3.fromRGB(40, 80, 140)
    Lighting.Brightness = 2.5
    Lighting.ClockTime = 6
    for i = 1, 2 do
        local p = Instance.new("Part")
        p.Shape = Enum.PartType.Ball
        p.Anchored = true
        p.CanCollide = false
        p.CastShadow = false
        p.Material = Enum.Material.Neon
        p.Transparency = 0.4
        local sz = 600 + i * 150
        p.Size = Vector3.new(sz, sz, sz)
        p.Color = Color3.fromRGB(40 + i * 30, 140 + i * 30, 255)
        p.Position = Vector3.new(math.cos(i * 2) * (2500 + i * 400), 1200 + i * 200, math.sin(i * 2) * (2500 + i * 400))
        p.Parent = workspace
        tagInstance(p)
        table.insert(gPlanets, p)
    end
    if not Connections.galaxySky then
        Connections.galaxySky = RunService.Heartbeat:Connect(function()
            if not Enabled.GalaxySky then return end
            local t = tick() * 0.4
            Lighting.Ambient = Color3.fromRGB(40 + math.sin(t) * 30, 80 + math.cos(t * 0.9) * 40, 140 + math.sin(t * 1.2) * 50)
            if gBloom then gBloom.Intensity = 1.0 + math.sin(t * 2.5) * 0.4 end
        end)
    end
end

function stopGalaxySky()
    if Connections.galaxySky then
        Connections.galaxySky:Disconnect()
        Connections.galaxySky = nil
    end
    if gSky then gSky:Destroy() gSky = nil end
    if origSky then origSky.Parent = Lighting origSky = nil end
    if gBloom then gBloom:Destroy() gBloom = nil end
    if gCC then gCC:Destroy() gCC = nil end
    for _, o in gPlanets do
        if o then o:Destroy() end
    end
    gPlanets = {}
    Lighting.Ambient = Color3.fromRGB(127, 127, 127)
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
end

