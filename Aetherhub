-- ==================== LOCK SYSTEM ====================
local lock_hbConn = nil
local lastBatSwingTime = 0

local function lock_getNearest()
    local char = Player.Character; if not char then return nil, nil, nil end
    local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return nil, nil, nil end
    local nearest, nearestDist, nearestPart = nil, math.huge, nil
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character then
            local targetHrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local part = plr.Character:FindFirstChild("UpperTorso") or plr.Character:FindFirstChild("Torso")
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if targetHrp and hum and hum.Health > 0 then
                local d = (targetHrp.Position - hrp.Position).Magnitude
                if d < nearestDist then nearestDist = d; nearest = targetHrp; nearestPart = part or targetHrp end
            end
        end
    end
    return nearest, nearestPart, nearestDist
end

local function lock_getBat()
    for _, t in ipairs(Player.Backpack:GetChildren()) do if t:IsA("Tool") and string.find(string.lower(t.Name), "bat", 1, true) then return t end end
    local char = Player.Character
    if char then for _, t in ipairs(char:GetChildren()) do if t:IsA("Tool") and string.find(string.lower(t.Name), "bat", 1, true) then return t end end end
    return nil
end

local function lock_start()
    local char = Player.Character; if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart"); local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end; hum.AutoRotate = true
    lock_hbConn = RunService.Heartbeat:Connect(function(dt)
        if not Enabled.BatAimbot then return end
        pcall(function()
            local c = Player.Character; if not c then return end
            local h = c:FindFirstChild("HumanoidRootPart"); local humanoid = c:FindFirstChildOfClass("Humanoid")
            if not h or not humanoid then return end
            local bat = lock_getBat(); if bat and bat.Parent ~= c then humanoid:EquipTool(bat) end
            local target, part, dist = lock_getNearest()
            if not target or not part then return end
            local tv = target.AssemblyLinearVelocity; local predFrames = dist / math.max(Values.BatAimbotSpeed, 1)
            local targetPos = target.Position + Vector3.new(tv.X * predFrames * 0.5, tv.Y * predFrames * 0.3, tv.Z * predFrames * 0.5)
            local currentPos = h.Position; local direction = (targetPos - currentPos)
            if direction.Magnitude > 0 then direction = direction.Unit end
            if math.abs(h.AssemblyLinearVelocity.Magnitude - Values.BatAimbotSpeed) > 1 then h.AssemblyLinearVelocity = direction * Values.BatAimbotSpeed end
            humanoid:Move((targetPos - currentPos).Unit, false)
            if dist < 7 then
                local now = tick()
                if now - lastBatSwingTime > 0.15 then
                    lastBatSwingTime = now; local currentBat = lock_getBat()
                    if currentBat and currentBat.Parent == c then currentBat:Activate() end
                end
            end
        end)
    end)
end

local function lock_stop()
    if lock_hbConn then lock_hbConn:Disconnect(); lock_hbConn = nil end
    local char = Player.Character
    if char then local hum = char:FindFirstChildOfClass("Humanoid"); if hum then hum.AutoRotate = true end end
end

