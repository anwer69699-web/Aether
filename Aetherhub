local autoLeftPhase, autoRightPhase = 0, 0
local autoLeftWaiting, autoRightWaiting = false, false

RunService.Heartbeat:Connect(function(dt)
    pcall(function()
        local char = getChar(); if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart"); local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        local isStealingAttr = Player:GetAttribute("Stealing") == true
        local currentSpeed = isStealingAttr and Values.StealingSpeedValue or Values.BoostSpeed

        if Enabled.SpeedBoost and not Enabled.AutoLeft and not Enabled.AutoRight and not Enabled.BatAimbot and not isDropping then
            local md = hum.MoveDirection
            if md.Magnitude > 0.05 then
                local dir = md.Unit
                hrp.AssemblyLinearVelocity = Vector3.new(dir.X * currentSpeed, hrp.AssemblyLinearVelocity.Y, dir.Z * currentSpeed)
            end
        end
        if Enabled.AutoLeft then
            if autoLeftWaiting then hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0); hum:Move(Vector3.zero, false)
            else
                if autoLeftPhase > #LeftWalkPositions then hum:Move(Vector3.zero, false); hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0); Enabled.AutoLeft = false; if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end; autoLeftPhase = 0; return end
                local wp = LeftWalkPositions[autoLeftPhase]; local tp = wp[1]; local isStealingPhase = wp[2]; local cp = Vector3.new(tp.X, hrp.Position.Y, tp.Z)
                if (cp - hrp.Position).Magnitude < 1.5 then autoLeftWaiting = true; task.delay(0.03, function() autoLeftWaiting = false; autoLeftPhase = autoLeftPhase + 1 end)
                else local d = (cp - hrp.Position); local md = Vector3.new(d.X, 0, d.Z).Unit; hum:Move(md, false); local ws = isStealingPhase == 2 and Values.StealingSpeedValue or Values.BoostSpeed; hrp.AssemblyLinearVelocity = Vector3.new(md.X * ws, hrp.AssemblyLinearVelocity.Y, md.Z * ws) end
            end
        end
        if Enabled.AutoRight then
            if autoRightWaiting then hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0); hum:Move(Vector3.zero, false)
            else
                if autoRightPhase == 0 then autoRightPhase = 1 end
                if autoRightPhase > #RightWalkPositions then hum:Move(Vector3.zero, false); hrp.AssemblyLinearVelocity = Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0); Enabled.AutoRight = false; if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end; autoRightPhase = 0; return end
                local wp = RightWalkPositions[autoRightPhase]; local tp = wp[1]; local isStealingPhase = wp[2]; local cp = Vector3.new(tp.X, hrp.Position.Y, tp.Z)
                if (cp - hrp.Position).Magnitude < 1.5 then autoRightWaiting = true; task.delay(0.03, function() autoRightWaiting = false; autoRightPhase = autoRightPhase + 1 end)
                else local d = (cp - hrp.Position); local md = Vector3.new(d.X, 0, d.Z).Unit; hum:Move(md, false); local ws = isStealingPhase == 2 and Values.StealingSpeedValue or Values.BoostSpeed; hrp.AssemblyLinearVelocity = Vector3.new(md.X * ws, hrp.AssemblyLinearVelocity.Y, md.Z * ws) end
            end
        end
        if Enabled.Galaxy then
            updateGalaxy()
            if spaceHeld and hum.FloorMaterial == Enum.Material.Air then hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, Values.HOP_POWER, hrp.AssemblyLinearVelocity.Z) end
        end
    end)
end)

