Player.CharacterAdded:Connect(function(char)
    StopDrop(); isDropping = false
    
    -- إعادة ضبط أنظمة الحركة المؤقتة
    Enabled.AutoLeft = false; Enabled.AutoRight = false; Enabled.BatAimbot = false
    if VisualSetters.AutoLeft then VisualSetters.AutoLeft(false, true) end
    if VisualSetters.AutoRight then VisualSetters.AutoRight(false, true) end
    if VisualSetters.BatAimbot then VisualSetters.BatAimbot(false, true) end
    lock_stop(); autoLeftPhase = 0; autoRightPhase = 0
    
    -- إعادة ضبط السرعة فوراً
    isStealing = false; animalCache = {}; promptCache = {}; stealCache = {}
    if ProgressLabel then ProgressLabel.Text = "READY" end
    if ProgressBarFill then ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
    if ProgressPercentLabel then ProgressPercentLabel.Text = "" end
    
    task.wait(1) -- انتظار تحميل الشخصية الجديدة بالكامل
    
    -- ربط الأنظمة الدائمة بالشخصية الجديدة تلقائياً (هنا السر!)
    if Enabled.SpeedBoost then
        -- السرعة تعمل تلقائياً لأنها تقرأ getChar() كل فريم، لا تحتاج إعادة تشغيل
    end
    if Enabled.Galaxy then
        setupGalaxyForce() -- يعيد ربط الـ VectorForce بالـ HRP الجديد
    end
    if Enabled.Unwalk then
        startUnwalk() -- يعيد حذف الأنيميشن للشخصية الجديدة
    end
    if Enabled.AntiRagdoll then
        stopAntiRagdoll() -- يقطع الاتصال القديم
        startAntiRagdoll() -- يربط مع الشخصية الجديدة
    end
    if Enabled.AutoSteal then
        startAutoStealLoop() -- يبدأ البحث من جديد
    end
    if Enabled.AntiLagger then
        stopAntiLagger() -- يعيد تعيين الـ Hooks للـ Remotes الجديدة
        startAntiLagger()
    end
    
    createSpeedBillboard()
end)
