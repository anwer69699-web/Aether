-- ═══════════════════════════════════════════════════════════════
-- CONFIG
-- ═══════════════════════════════════════════════════════════════
local function SaveConfig()
    local data = {}
    for k, v in pairs(Values) do data[k] = v end
    if writefile then
        pcall(function() writefile(ConfigFileName, HttpService:JSONEncode(data)) end)
    end
end

local function LoadConfig()
    if not (readfile and isfile and isfile(ConfigFileName)) then return false end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigFileName)) end)
    if not ok or not data then return false end
    for k, v in pairs(data) do
        if Values[k] ~= nil then Values[k] = v end
    end
    return true
end
LoadConfig()

